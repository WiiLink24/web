---
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import Layout from "../../../layouts/Layout.astro";
import i18next, { t, changeLanguage } from "i18next";
import { Trans, HeadHrefLangs } from "astro-i18next/components";

changeLanguage("en");
---

<Layout
  title={t("account-privacy.mainTitle")}
  description={t("account-privacy.mainDesc")}
  image="/img/branding_bg.webp">
  <Header isGuide="display:none;" />

  <div class="sectiontop" style="top:200px !important; position:relative;">
    <section class="section">
      <h1 style="font-family: Gilroy; margin-bottom: 18px;">
        {t("account-privacy.title")}
      </h1>
      <h3
        class="update"
        style="width:270px; top:20px; right:0; padding:10px; border-radius:8px; font-size:20px; font-family:inter; background-color:#00000060; position:absolute;"
        class="updated">
        Last updated: 04/04/2026
      </h3>
      <div class="polka-dot"></div>
      <p
        class="title"
        style="filter:opacity(0.3); font-family:inter; transform:translate(0, -20px);">
        {t("account-privacy.desc")}
      </p>
      <section class="section">
        <l class="notice info fullwidth">
          <Trans i18nKey="privacyPolicy.looking-for-main">
          Looking for our main Privacy Policy?
          Find it <a href="/privacy-policy">here</a>.
          </Trans>
        </l></br></br>
        <p class="title">{t("privacyPolicy.title")}</p>
        <p>
          {t("privacyPolicy.protection")}
          <br /><br />
          {t("privacyPolicy.read")}
          <br /><br />
          <Trans i18nKey="account-privacy.consent">
          By using WiiLink Accounts, you consent to our practices stated in this
          document. If you do not consent, please do not use WiiLink Accounts.
          If you have any questions or concerns about this Privacy Policy, do not
          hesitate to reach out to staff in our Discord server, or by emailing
          <a href="mailto:support@wiilink.ca">support@wiilink.ca</a>.
          </Trans>
          <br />
          <br />
          <p class="title">{t("privacyPolicy.access")}</p>
          {t("privacyPolicy.stored-data")}
          <ul style="list-style-type: square">
            <li>{t("account-privacy.account")}</li>
            <li>{t("account-privacy.username")}</li>
            <li>{t("account-privacy.email")}</li>
            <li>{t("account-privacy.ip-address")}</li>
          </ul>
          {t("account-privacy.geo-ip")}
          <br /><br />
          {t("account-privacy.linked-console")}
          <ul style="list-style-type: square">
            <li>{t("account-privacy.wii-number")}</li>
            <li>{t("account-privacy.console-id")}</li>
            <li>{t("account-privacy.serial-number")}</li>
          </ul>

          {t("account-privacy.dont-sell-data")}
          <br />
          <br />
          <Trans i18nKey="account-privacy.delete-account">
          You can exercise your right to be forgotten by deleting your account
          <a href="https://sso.riiconnect24.net/if/user/#/settings">here</a>.
          </Trans>
          <br />
          <br />
          <p class="title">{t("privacyPolicy.children-privacy")}</p>
          <section class="section">
            <div class="container">
              <div class="notification is-danger">
                <Trans i18nKey="privacyPolicy.not-intented-for-children">
                <strong>Important!</strong><br />This service is not intended
                for children under the age of 13.
                </Trans>
              </div>
            </div>
          </section>
          <p>
            {t("privacyPolicy.dont-collect-info")}
          </p>

          <p class="title">{t("privacyPolicy.changes")}</p>
          <p>
            {t("privacyPolicy.change-notification")}
          </p>
        </p>
        <br><br>
        <p class="title">
            {t("privacyPolicy.last-modified")}
        </p>
        <p>
            Saturday, April 4th, 2026
        </p>
      </section>
      </section>
      <Footer />

      <style>
        .section {
          max-width: 1500px;
          padding-left: 5px;
          padding-right: 5px;
          left: 50%;
          transform: translate(-50%, 0);
          margin-bottom: 80px;
          position: relative;
          font-family: inter;
        }
        .title {
          font-family: Gilroy;
          font-size: 30px;
        }

        .socials {
          top: 50%;
          right: 50px;
          transform: translate(0, -50%);
          color: white;
          font-size: 25px;
          width: 150px;
          justify-content: right;
          display: flex;
          flex-wrap: wrap;
          position: absolute;
        }
        .slogan {
          left: 80px;
          font-family:
            inter,
            -apple-system,
            BlinkMacSystemFont,
            "Segoe UI",
            Roboto,
            Oxygen,
            Ubuntu,
            Cantarell,
            "Open Sans",
            "Helvetica Neue",
            sans-serif;
          color: white;
          width: 500px;
          position: relative;
        }
        .footer-holder {
          bottom: 20px;
          left: 50%;
          transform: translate(-50%, 0);
          display: flex;
          align-items: center;
          width: 98%;
          height: 250px;
          position: absolute;
        }

        .symbolholder {
          background-color: var(--bg-color);
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          transition: 0.5s;
          z-index: 1;
          overflow: hidden;
          position: fixed;
        }

        .backsymbol {
          width: 100%;
          height: 100%;
          top: 0%;
          left: 50%;
          transform: translate(-50%, 0);
          z-index: 1;
          position: absolute;
        }
        .contentholder {
          left: 50%;
          transform: translate(-50%, 0);
          max-width: 1000px;
          position: relative;
        }
        .bottomleftcorner {
          animation: changecolor 10s linear infinite;
          position: relative;
        }
        .bottomleftcornerholder {
          left: -2.6px;
          bottom: -3px;
          scale: 31.6%;
          transform: translate(-106.5%, 107.3%);
          z-index: 2;
          position: absolute;
        }
        .square {
          --img-invert: 0;
          width: 100%;
          height: 100%;
          background: linear-gradient(
            41deg,
            rgba(0, 138, 255, 1) 0%,
            rgba(255, 0, 59, 1) 100%
          );
          z-index: 0;
          animation: changecolor 10s linear infinite;
          position: absolute;
        }
        #square2 {
          width: 100%;
          height: 100%;
          left: 0;
          top: 0;
          background-color: #ffffff;
          transform: translate(0%, 0%);
          border-radius: 4px;
          z-index: 1;

          transition: 0.5s;
          overflow-y: scroll;
          overflow-x: hidden;
          position: absolute;
        }

        .polka-dot {
          width: 240px;
          height: 240px;
          background-image: radial-gradient(#000 10%, transparent 11%),
            radial-gradient(#000 10%, transparent 11%);
          background-size: 30px 30px;
          background-position:
            0 0,
            30px 30px;
          opacity: 0.1;
          rotate: 30deg;
          left: -50px;
          top: -38px;
          background-repeat: repeat;
          animation: rotate 240s linear infinite;
          position: absolute;
          z-index: 0;
        }

        @keyframes rotate {
          0% {
            rotate: 0deg;
          }
          100% {
            rotate: 360deg;
          }
        }

        .notification {
          background-color: #292929;
          color: black;
          padding: 20px;
          font-family: Gilroy;
          border-radius: 8px;
          border: 2px solid #ffffff20;
          text-align: center;
        }

        .is-danger {
          background-color: #db0f0f20;
          border: 4px solid #db0f0f80;
        }

        .is-warning {
          background-color: #c9b81620;
          border: 4px solid #c9b81680;
        }

        strong {
          font-family: Gilroy;
          font-size: 20px;
        }

        @media (max-width: 1000px) {
          .update {
            display: none;
          }
        }
      </style>
    </section>
  </div></Layout
>
